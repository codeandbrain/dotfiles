# =====================================================================
# §13 — PROMPT
# =====================================================================
# Shows: user@host : dir (git-branch) $
# Green = clean branch, Yellow = uncommitted changes

__zs_git_prompt() {
    local branch
    branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) || return
    local dirty=$(git status --porcelain 2>/dev/null | wc -l)
    if [ "$dirty" -gt 0 ]; then
        echo -e " \e[33m($branch ✗)\e[0m"
    else
        echo -e " \e[32m($branch)\e[0m"
    fi
}

PS1='\[\e[36m\]\u@\h\[\e[0m\]:\[\e[34m\]\w\[\e[0m\]$(__zs_git_prompt)\$ '

