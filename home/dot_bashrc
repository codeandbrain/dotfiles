# =====================================================================
# §2 — PATH: SAFE DEDUPLICATION
# =====================================================================
# This function adds a directory to PATH only if it is not already there.
# Prevents the PATH duplication that happens when .bashrc is sourced
# multiple times or when export commands are appended repeatedly.

__add_to_path() {
    case ":${PATH}:" in
        *":$1:"*) ;;          # already in PATH — skip
        *) export PATH="$1:$PATH" ;;
    esac
}

__add_to_path "$HOME/.local/bin"
__add_to_path "/usr/local/go/bin"
__add_to_path "$HOME/go/bin"
__add_to_path "$HOME/.cargo/bin"

