# Show git status of every ZarishSphere repo at a glance
zsstatus() {
    echo "=== ZarishSphere Workspace Status ==="
    local repos=(
        "$ZS_PLATFORM" "$ZS_CORE" "$ZS_FHIR" "$ZS_FHIR_G2A"
        "$ZS_INDEX" "$ZS_STANDARDS" "$ZS_NOTE" "$ZS_DOCS"
        "$ZS_CONSOLE" "$ZS_MARKETPLACE" "$ZS_BUILDER" "$ZS_FORMS"
        "$ZS_SDK" "$ZS_CLI" "$ZS_API" "$ZS_ENGINE"
        "$ZS_HEALTH" "$ZS_EDUCATION" "$ZS_LOGISTICS"
        "$ZS_PROTECTION" "$ZS_WASH" "$ZS_NUTRITION"
        "$ZS_INFRA_CF" "$ZS_GITHUB" "$ZS_DOTFILES"
    )
    for repo in "${repos[@]}"; do
        local name=$(basename "$repo")
        if [ -d "$repo/.git" ]; then
            local branch=$(git -C "$repo" rev-parse --abbrev-ref HEAD 2>/dev/null)
            local dirty=$(git -C "$repo" status --porcelain 2>/dev/null | wc -l)
            if [ "$dirty" -gt 0 ]; then
                printf "  \e[33m✗\e[0m %-35s [\e[33m%s\e[0m] %s uncommitted\n" "$name" "$branch" "$dirty"
            else
                printf "  \e[32m✓\e[0m %-35s [\e[32m%s\e[0m]\n" "$name" "$branch"
            fi
        else
            printf "  \e[90m—\e[0m %-35s [not cloned]\n" "$name"
        fi
    done
}

# Pull latest in all repos
zspull() {
    echo "=== Pulling all ZarishSphere repos ==="
    local repos=(
        "$ZS_PLATFORM" "$ZS_CORE" "$ZS_FHIR" "$ZS_FHIR_G2A"
        "$ZS_INDEX" "$ZS_STANDARDS" "$ZS_NOTE" "$ZS_DOCS"
        "$ZS_CONSOLE" "$ZS_MARKETPLACE" "$ZS_BUILDER" "$ZS_FORMS"
        "$ZS_SDK" "$ZS_CLI" "$ZS_API" "$ZS_ENGINE"
        "$ZS_HEALTH" "$ZS_EDUCATION" "$ZS_LOGISTICS"
        "$ZS_PROTECTION" "$ZS_WASH" "$ZS_NUTRITION"
        "$ZS_INFRA_CF" "$ZS_GITHUB"
    )
    for repo in "${repos[@]}"; do
        if [ -d "$repo/.git" ]; then
            printf "→ %-40s " "$(basename $repo)"
            git -C "$repo" pull --ff-only 2>&1 | tail -1
        fi
    done
    echo "=== Done ==="
}

# Clone all ZarishSphere org repos into ~/zarishsphere/
zsclone() {
    echo "=== Cloning ZarishSphere org repos ==="
    mkdir -p "$ZS_HOME"
    local repos=(
        "zs-platform" "zs-core" "zs-fhir-server" "zs-fhir-g2a"
        "zarish-index" "zs-standards" "zarish-note" "zs-docs"
        "zs-console" "zs-marketplace" "zs-builder" "zs-forms"
        "zs-sdk" "zs-cli" "zs-api" "zs-engine"
        "zs-health" "zs-education" "zs-logistics"
        "zs-protection" "zs-wash" "zs-nutrition"
        "zs-infra-cloudflare" ".github"
    )
    for repo in "${repos[@]}"; do
        if [ -d "$ZS_HOME/$repo/.git" ]; then
            echo "→ $repo [already cloned — skipping]"
        else
            echo "→ Cloning $repo..."
            git clone git@github.com:zarishsphere/$repo.git "$ZS_HOME/$repo" 2>&1 | tail -1
        fi
    done
    echo "=== Done. Run 'zsstatus' to verify ==="
}

# Shallow clone one repo (for slow/mobile connections)
# Usage: zsclone-shallow zs-fhir-server
zsclone-shallow() {
    [ -z "$1" ] && echo "Usage: zsclone-shallow <repo-name>" && return 1
    git clone --depth=1 --single-branch --branch=main \
        git@github.com:zarishsphere/$1.git "$ZS_HOME/$1" && \
    echo "Shallow clone done. To get full history: git -C $ZS_HOME/$1 fetch --unshallow"
}

# Search all repos for a term
# Usage: zsgrep "search term"
zsgrep() {
    [ -z "$1" ] && echo "Usage: zsgrep <pattern>" && return 1
    grep -r --include="*.md" --include="*.yml" --include="*.yaml" \
         --include="*.json" --include="*.go" -l "$1" "$ZS_HOME" 2>/dev/null
}

# Generate next ZI-UID for a domain
# Usage: zi-uid HEALTH
zi-uid() {
    [ -z "$1" ] && echo "Usage: zi-uid <DOMAIN> (e.g. zi-uid HEALTH)" && return 1
    local domain="${1^^}"
    local count=$(find "$ZS_INDEX" -name "*.yml" 2>/dev/null | \
                  xargs grep -l "ZI-${domain}" 2>/dev/null | wc -l)
    local next=$(printf "%05d" $((count + 1)))
    echo "ZI-${domain}-${next}"
}

# ZUSS naming compliance check in current directory
zuss-check() {
    echo "=== ZUSS naming check in $(pwd) ==="
    find . -maxdepth 3 -not -path './.git/*' | grep '[A-Z]' | \
        sed 's/^/  UPPERCASE: /'
    find . -maxdepth 3 -not -path './.git/*' | grep ' ' | \
        sed 's/^/  SPACE IN NAME: /'
    find . -maxdepth 3 -name "*_*" -not -path './.git/*' | \
        sed 's/^/  UNDERSCORE: /'
    echo "Check complete."
}

